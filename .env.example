# ============================================================
# FoodWise — environment variable template
# ============================================================
# Copy this file to .env and fill in the placeholders before
# running `docker compose up`. `.env` is gitignored — never
# commit it.
#
# Local IDE / ./gradlew bootRun runs do NOT need this file —
# application.yml provides dev-safe fallbacks
# (PostgreSQL superuser tapok332/admin created by
# init-databases.sql). See docs/decisions/0008.
#
# Generate fresh secrets with:
#   openssl rand -base64 32
# ============================================================

# --- JWT secrets (mandatory) ---
# Two distinct secrets — never reuse the access secret for refresh.
JWT_SECRET_ACCESS=replace_me_openssl_rand_base64_32
JWT_SECRET_REFRESH=replace_me_openssl_rand_base64_32

# --- Internal service-to-service auth ---
# Shared symmetric key gateway uses to sign X-Internal-Service-Secret
# header so downstream services trust requests coming from the gateway.
INTERNAL_SERVICE_SECRET=replace_me_openssl_rand_base64_32

# --- PostgreSQL superuser (used by `postgres` container only) ---
POSTGRES_USER=foodwise_admin
POSTGRES_PASSWORD=replace_me_strong_random

# --- Per-service DB credentials ---
# init-databases.sql creates one user per service with rights scoped
# to that service's database. Each service's container picks up
# SPRING_DATASOURCE_USERNAME / SPRING_DATASOURCE_PASSWORD from these.
AUTH_DB_USER=auth_user
AUTH_DB_PASSWORD=replace_me_strong_random
PROFILE_DB_USER=profile_user
PROFILE_DB_PASSWORD=replace_me_strong_random
STORE_DB_USER=store_user
STORE_DB_PASSWORD=replace_me_strong_random
SURPRISEBOX_DB_USER=surprisebox_user
SURPRISEBOX_DB_PASSWORD=replace_me_strong_random
CART_DB_USER=cart_user
CART_DB_PASSWORD=replace_me_strong_random
ORDER_DB_USER=order_user
ORDER_DB_PASSWORD=replace_me_strong_random
PAYMENT_DB_USER=payment_user
PAYMENT_DB_PASSWORD=replace_me_strong_random
FAVORITES_DB_USER=favorites_user
FAVORITES_DB_PASSWORD=replace_me_strong_random

# --- CORS ---
# Comma-separated list of origins gateway accepts.
CORS_ALLOWED_ORIGINS=http://localhost:3000

# --- Swagger UI ---
# Set to false for any non-local deployment.
SWAGGER_ENABLED=true

# --- Stripe (test mode) ---
# Test keys from https://dashboard.stripe.com/test/apikeys.
# Webhook secret is per-endpoint — get one by configuring a webhook
# in the Stripe dashboard pointed at /payments/webhook/stripe.
STRIPE_SECRET_KEY=sk_test_replace_me
STRIPE_WEBHOOK_SECRET=whsec_replace_me
STRIPE_PUBLISHABLE_KEY=pk_test_replace_me
STRIPE_API_VERSION=2024-12-18.acacia
PAYMENT_DEFAULT_PROVIDER=stripe
PAYMENT_DEFAULT_CURRENCY=uah

# --- Frontend (Next.js — only NEXT_PUBLIC_ vars get into the bundle) ---
# The publishable Stripe key is *meant* to ship to the browser; the
# secret one above must not.
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_replace_me
NEXT_PUBLIC_DEFAULT_LAT=50.4501
NEXT_PUBLIC_DEFAULT_LNG=30.5234

# --- Store service tz ---
STORE_TIMEZONE=Europe/Kyiv
